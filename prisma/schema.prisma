generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  users     User[]
  cases     Case[]
  createdAt DateTime @default(now())
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  password       String
  name           String
  role           String       @default("USER")
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
}

model Case {
  id             String       @id @default(cuid())
  name           String
  client         String
  type           String
  manager        String
  status         String       @default("ACTIVE")
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  documents      Document[]
  financialData  FinancialValue[]
  industry       IndustryClassification?
  valuationModels ValuationModel[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Document {
  id        String   @id @default(cuid())
  name      String
  type      String
  size      String
  s3Key     String?  // Stores the path/key in the S3 bucket
  status    String   @default("PENDING")
  case      Case     @relation(fields: [caseId], references: [id])
  caseId    String
  createdAt DateTime @default(now())
}

model FinancialValue {
  id            String   @id @default(cuid())
  case          Case     @relation(fields: [caseId], references: [id])
  caseId        String
  year          String
  statementType String
  lineItem      String
  value         Float?
  currency      String   @default("USD")
  createdAt     DateTime @default(now())
}

model IndustryClassification {
  id                String   @id @default(cuid())
  case              Case     @relation(fields: [caseId], references: [id])
  caseId            String   @unique
  suggestedIndustry String
  naicsCode         String?
  sicCode           String?
  updatedAt         DateTime @updatedAt
}

model ValuationModel {
  id            String   @id @default(cuid())
  case          Case     @relation(fields: [caseId], references: [id])
  caseId        String
  ebitda        Float
  multiplier    Float
  growthRate    Float
  valuationType String
  createdAt     DateTime @default(now())
}
